# ==================================
# WIWIGA - Variables d'Environnement
# ==================================
# Copier ce fichier en .env et remplir les valeurs
# NE PAS commiter .env dans git !

# ==================================
# Base de Données PostgreSQL
# ==================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/game_hub_dev
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/game_hub_test
DB_POOL_SIZE=10
DB_TIMEOUT=5000

# ==================================
# Redis
# ==================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================================
# Authentification JWT (Guardian)
# ==================================
GUARDIAN_SECRET_KEY=votre_secret_key_tres_long_et_securise_ici_32_chars_minimum
GUARDIAN_ISSUER=game_hub
GUARDIAN_TTL_SECONDS=86400

# ==================================
# Paiement Campay
# ==================================
CAMPAY_WEBHOOK_SECRET_KEY=votre_secret_key_campay_ici
CAMPAY_API_URL=https://demo.campay.net/api
CAMPAY_APP_USERNAME=votre_app_username
CAMPAY_APP_PASSWORD=votre_app_password

# ==================================
# Environment
# ==================================
MIX_ENV=dev
PORT=4000
SECRET_KEY_BASE=votre_secret_key_base_tres_long_phoenix_ici_minimum_64_chars
LIVE_RELOAD=true

# ==================================
# Production Settings
# ==================================
LOG_LEVEL=info
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ENABLE_HTTPS=false

# ==================================
# Monitoring (Optionnel)
# ==================================
ENABLE_HEALTH_CHECKS=true
ENABLE_METRICS=false
METRICS_PORT=4001
